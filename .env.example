# MySQL
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=blog

# Auth（首次运行请执行 npm run auth:keys）
AUTH_JWT_PRIVATE_KEY_PATH=.keys/jwt-private.pem
AUTH_JWT_PUBLIC_KEY_PATH=.keys/jwt-public.pem
AUTH_RSA_PRIVATE_KEY_PATH=.keys/rsa-private.pem
AUTH_RSA_PUBLIC_KEY_PATH=.keys/rsa-public.pem
AUTH_COOKIE_NAME=blog_auth
AUTH_JWT_EXPIRES_IN=7d
AUTH_BOOTSTRAP_USERNAME=admin
AUTH_BOOTSTRAP_PASSWORD=admin123

# Wikilink 链接前缀
PUBLIC_WIKILINK_BASE_PATH=/blog
ADMIN_WIKILINK_BASE_PATH=/admin/posts

# 本地 Ollama AI（需 ollama pull qwen3.5:0.8b 与 ollama pull nomic-embed-text）
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_CHAT_MODEL=qwen3.5:0.8b
OLLAMA_EMBED_MODEL=nomic-embed-text
AI_ENABLED=true
AI_MAX_CONTEXT_CHUNKS=4
AI_WIKILINK_MAX_SUGGESTIONS=6
AI_REQUEST_TIMEOUT_MS=120000
AI_PUBLIC_RATE_LIMIT_PER_MIN=10
